{
  "$schema": "https://opencode.ai/config.json",
  
  "provider": {
    "example-openai-compatible": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenAI-Compatible Endpoint",
      "options": {
        "baseURL": "https://your-api.example.com/v1"
      },
      "models": {
        "your-model-id": {
          "name": "Your Model Display Name",
          "limit": {
            "context": 128000,
            "output": 4096
          }
        }
      }
    },
    
    "example-anthropic": {
      "name": "Anthropic Custom Endpoint",
      "options": {
        "baseURL": "https://your-anthropic-proxy.example.com"
      }
    },
    
    "example-ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (Remote Server)",
      "options": {
        "baseURL": "http://your-server-ip:11434/v1"
      },
      "models": {
        "llama3": {
          "name": "Llama 3"
        },
        "codellama": {
          "name": "Code Llama"
        }
      }
    },
    
    "example-vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "vLLM Server",
      "options": {
        "baseURL": "http://your-vllm-server:8000/v1"
      },
      "models": {
        "mistral": {
          "name": "Mistral"
        }
      }
    },
    
    "example-litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM Proxy",
      "options": {
        "baseURL": "http://your-litellm-proxy:4000/v1"
      },
      "models": {
        "gpt-4": {
          "name": "GPT-4 (via LiteLLM)"
        },
        "claude-3": {
          "name": "Claude 3 (via LiteLLM)"
        }
      }
    }
  },
  
  "model": "example-openai-compatible/your-model-id",
  
  "small_model": "example-openai-compatible/your-model-id",
  
  "agent": {
    "build": {
      "model": "example-openai-compatible/your-model-id",
      "prompt": "You are a helpful coding assistant.",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "plan": {
      "model": "example-openai-compatible/your-model-id",
      "prompt": "You are a planning agent. Analyze tasks and create implementation plans without making changes.",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    }
  },
  
  "default_agent": "build",
  
  "permission": {
    "*": "allow",
    "bash": "ask",
    "edit": "ask"
  },
  
  "share": "manual"
}